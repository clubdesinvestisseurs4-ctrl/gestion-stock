# Firebase Web SDK (Firebase Console > Paramètres du projet > Vos applications > Web)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Notifications push (Firebase Console > Paramètres du projet > Cloud Messaging >
# Configuration Web > "Générer une paire de clés")
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key

# URL du backend (Render en production)
VITE_API_BASE_URL=http://localhost:3001/api
