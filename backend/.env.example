PORT=3001
NODE_ENV=development

# ─── Méthode recommandée pour Render (Base64 du fichier JSON complet) ───────
# Générer avec : base64 -w 0 serviceAccountKey.json  (Linux/Mac)
# Ou PowerShell : [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ─── Méthode alternative (variables individuelles, pour le dev local) ────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id

# CORS - URL du frontend déployé
FRONTEND_URL=http://localhost:5173
